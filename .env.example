# ACAS v2 - Environment Configuration
# Copy to .env and fill in real values

# =============================================================================
# SECURITY WARNING: DO NOT USE DEFAULT VALUES IN PRODUCTION!
# Generate secure keys using: python -c "import secrets; print(secrets.token_urlsafe(32))"
# =============================================================================

# Application
ACAS_ENVIRONMENT=development
ACAS_DEBUG=true

# Security - MUST BE CHANGED IN PRODUCTION
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ACAS_SECRET_KEY=GENERATE_A_SECURE_KEY_MIN_32_CHARS_CHANGE_ME
ACAS_ENCRYPTION_KEY=  # Optional: Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Database
ACAS_DB_URL=postgresql+psycopg://acas:CHANGE_ME_PASSWORD@localhost:5432/acas
ACAS_DB_POOL_SIZE=20
ACAS_DB_MAX_OVERFLOW=40

# Redis
ACAS_REDIS_URL=redis://localhost:6379/0
ACAS_REDIS_PASSWORD=  # Optional

# API Server
ACAS_API_HOST=0.0.0.0
ACAS_API_PORT=8000
ACAS_API_WORKERS=4
ACAS_API_CORS_ORIGINS=https://your-domain.com,https://app.your-domain.com
ACAS_API_CORS_ALLOW_CREDENTIALS=true

# Rate Limiting
ACAS_RL_ENABLED=true
ACAS_RL_DEFAULT=100:60
ACAS_RL_LOGIN=5:300
ACAS_RL_REGISTER=3:3600

# ML Configuration
ACAS_ML_TIMESFM_ENABLED=true
ACAS_ML_TIMESFM_MODEL_PATH=
ACAS_ML_TIMESFM_CONTEXT_LENGTH=512
ACAS_ML_TIMESFM_PREDICTION_HORIZON=96

# Monitoring
ACAS_MON_LOG_LEVEL=INFO
ACAS_MON_LOG_FORMAT=json
ACAS_MON_SENTRY_DSN=  # Optional
ACAS_MON_PROMETHEUS_ENABLED=true

# External APIs (optional)
NEWS_API_KEY=  # For premium news sources
ALPHA_VANTAGE_KEY=  # For financial data
